---
import BaseLayout from "../layouts/BaseLayout.astro";
import { featuredProjects } from "../data/projects";

const skills = [
  {
    area: "LLM · Agent",
    items: ["LangGraph", "LangChain", "OpenAI API", "Hugging Face", "Qdrant", "Neo4j"],
  },
  {
    area: "ML · 데이터",
    items: ["PyTorch", "scikit-learn", "LightGBM", "XGBoost", "CatBoost", "pandas"],
  },
  {
    area: "서빙 · 인프라",
    items: ["FastAPI", "Redis", "PostgreSQL", "Docker", "Nginx", "GitHub Actions"],
  },
  {
    area: "웹",
    items: ["React", "Next.js", "TypeScript"],
  },
];

const experience = [
  {
    company: "데이콘",
    role: "Data Science팀 매니저",
    period: "2025.12 – 현재",
    summary: "공공 데이터 분석 과제 2건의 PL과 데이터 사이언스 경진대회 기획·운영을 맡고 있습니다.",
    bullets: [
      "운수종사자 교통사고 위험 예측 모델·관리 웹 개발 PL (2025.12 – 2026.04 · 행안부·NIA·한국교통안전공단 위탁) — 검사 결과와 사고 이력을 학습한 앙상블 예측 모델과 관리 웹을 개발하고, 발주기관의 쿠버네티스 기반 폐쇄망 클라우드 환경에 실제 배포까지 완료",
      "AI 기반 수요기관 자체입찰 모니터링 모델 개발 PL (2026.06 – 현재 · 행안부·NIA·조달청 위탁) — 진행 중",
      "AI 경진대회·해커톤의 과제 설계, 대회용 데이터 구성, 참가자·리더보드 운영",
    ],
  },
  {
    company: "슈어소프트테크",
    role: "AX응용기술팀 AI 개발자 (인턴)",
    period: "2025.06 – 2025.11",
    summary: "해양수산부·해양경찰청 R&D 과제의 개발 실무를 맡고, KT와 에이전트 신뢰성 검증을 함께 수행했습니다.",
    bullets: [
      "해양 법령 도메인 RAG 개발 (해양경찰청 CDX 과제 · 해양정보기술 주관) — 법령 도메인 RAG DB 구축과 LangGraph 기반 검색·답변 흐름 구성",
      "해양사고 위험 분석 (해양수산부 AI융복합 과제 · 선박해양플랜트연구소 주관) — 격자×시간 단위 데이터 결합, 통계 검증, 모델 해석",
      "KT 자율 에이전트 신뢰성 검증 — 검증 데이터셋 구축, 실성능 테스트, 화이트리스트 작성 (KT와 공동 수행)",
    ],
  },
];

const awards = [
  {
    title: "유전체 정보 품종 분류 AI 경진대회 · 1등",
    detail: "716팀 중 1위 (상위 0.1%) · 충남대학교 바이오AI융합연구센터 외 주최 · 데이콘 주관",
    date: "2023.02",
  },
  {
    title: "법원 판결 예측 AI 경진대회 · 2등",
    detail: "506팀 중 2위 (상위 0.4%) · 데이콘 주최/주관",
    date: "2023.07",
  },
];

const competitions = [
  {
    title: "제3회 국민대학교 AI빅데이터 분석 경진대회",
    result: "50등 / 960팀 (상위 5.2%)",
    detail: "국민대 경영대학원·기계산업진흥회 주최",
    date: "2025.11",
  },
  {
    title: "운수종사자 인지적 특성 데이터 활용 교통사고 위험 예측 AI 경진대회",
    result: "34등 / 437팀 (상위 7.8%)",
    detail: "행정안전부·NIA 주최 · 한국교통안전공단 주관",
    date: "2025.10 – 2025.11",
  },
  {
    title: "HD현대 AI Challenge",
    result: "예선 2등 / 330팀 (상위 0.6%) · 본선 6등",
    detail: "HD한국조선해양 AI Center 주최 · 데이콘 주관",
    date: "2023.09 – 2023.10",
  },
  {
    title: "온라인 채널 제품 판매량 예측 AI 온라인 해커톤",
    result: "예선 12등 / 747팀 (상위 1.6%) · 본선 24등",
    detail: "LG AI Research 주최 · 데이콘 주관 · LG Aimers 연계",
    date: "2023.08",
  },
  {
    title: "2023 전력사용량 예측 AI 경진대회",
    result: "107등 / 1,233팀 (상위 8.7%)",
    detail: "한국에너지공단 주최 · 데이콘 주관",
    date: "2023.07 – 2023.08",
  },
  {
    title: "감귤 착과량 예측 AI 경진대회",
    result: "17등 / 257팀 (상위 6.6%)",
    detail: "제주테크노파크 주최 · 데이콘 주관",
    date: "2022.12",
  },
];

const activities = [
  { title: "국민대학교 경영대학 · 연결고리 14기 멘티 (현업 동문 진로 멘토링)", date: "2023.10 – 2023.11" },
  { title: "BDA (현 BDAI, 대학생 연합 빅데이터 학회) · 7기 데이터 분석 고급반 수료", date: "2023.09 – 2024.03" },
  { title: "LG AI Research · LG Aimers 3기 교육생", date: "2023.07 – 2023.09" },
  { title: "D&A (국민대학교 빅데이터 분석 학회) · 딥러닝 세션", date: "2023.03 – 2023.12" },
  { title: "D&A · 머신러닝 세션", date: "2022.03 – 2022.12" },
  { title: "D&A · Python 기초 스터디", date: "2021.12 – 2022.01" },
];
---

<BaseLayout
  title="CV · 강민수"
  description="강민수 | Minsu Kang의 이력 — 기술 스택, 경력, 대표 프로젝트, 학력, 수상·대회, 논문, 자격증."
  sideBarActiveItemID="cv"
>
  <!-- Header -->
  <header class="cv-header mb-10">
    <p class="text-xs font-mono opacity-60 tracking-widest uppercase mb-2">Curriculum Vitae</p>
    <div class="flex items-start justify-between gap-4 flex-wrap">
      <div class="grow">
        <h1 class="text-4xl md:text-5xl font-bold leading-tight tracking-tight">강민수</h1>
        <p class="text-xl md:text-2xl mt-1 opacity-80 font-light">Minsu Kang</p>
        <p class="mt-4 text-base md:text-lg font-semibold break-keep">LLM 에이전트와 ML 시스템을 만들고, 실제로 돌아가는 서비스로 배포합니다.</p>
      </div>
      <button
        type="button"
        class="btn btn-sm btn-outline print:hidden"
        onclick="window.print()"
        aria-label="이력서 인쇄"
      >
        Print
      </button>
    </div>

    <dl class="cv-meta mt-6 grid grid-cols-1 md:grid-cols-3 gap-x-6 gap-y-2 text-sm border-t border-b border-base-300 py-4">
      <div class="flex gap-2">
        <dt class="opacity-50 font-mono uppercase tracking-wide w-16 shrink-0">Email</dt>
        <dd>
          <a href="mailto:daro980722@gmail.com" class="link link-hover">daro980722@gmail.com</a>
        </dd>
      </div>
      <div class="flex gap-2">
        <dt class="opacity-50 font-mono uppercase tracking-wide w-16 shrink-0">GitHub</dt>
        <dd>
          <a href="https://github.com/Minsu5452" target="_blank" rel="noopener" class="link link-hover">github.com/Minsu5452</a>
        </dd>
      </div>
      <div class="flex gap-2">
        <dt class="opacity-50 font-mono uppercase tracking-wide w-16 shrink-0">DACON</dt>
        <dd>
          <a href="https://dacon.io/myprofile/457768/home" target="_blank" rel="noopener" class="link link-hover">View profile</a>
        </dd>
      </div>
      <div class="flex gap-2">
        <dt class="opacity-50 font-mono uppercase tracking-wide w-16 shrink-0">Based</dt>
        <dd>Seoul, South Korea</dd>
      </div>
      <div class="flex gap-2">
        <dt class="opacity-50 font-mono uppercase tracking-wide w-16 shrink-0">Now</dt>
        <dd>데이콘 · Data Science팀 매니저</dd>
      </div>
      <div class="flex gap-2">
        <dt class="opacity-50 font-mono uppercase tracking-wide w-16 shrink-0">Edu</dt>
        <dd>국민대 · AI빅데이터융합경영학과</dd>
      </div>
    </dl>
  </header>

  <!-- Summary -->
  <section class="cv-section mb-10">
    <h2 class="cv-h">Summary</h2>
    <p class="opacity-90 leading-relaxed">
      LLM 에이전트와 ML 시스템을 만들고 실제 서비스로 배포하는 AI 엔지니어입니다.
      교통·해양·법률 등 여러 도메인에서 ML 모델과 LLM/RAG 시스템, 웹 서비스를 설계·개발했고,
      현재 데이콘에서 공공 데이터 분석 과제 2건을 PL로 수행하며 데이터 사이언스 경진대회 기획·운영을 함께 하고 있습니다.
      데이콘 플랫폼 대회에서 1위·2위를 포함해 8개 대회 상위권을 기록했습니다.
    </p>
  </section>

  <!-- Skills -->
  <section class="cv-section mb-10">
    <h2 class="cv-h">Skills</h2>
    <div class="grid gap-2.5">
      {
        skills.map((row) => (
          <div class="grid grid-cols-1 md:grid-cols-[8rem_1fr] gap-1 md:gap-3 items-baseline">
            <div class="text-sm font-semibold opacity-70">{row.area}</div>
            <div class="flex flex-wrap gap-1.5">
              {row.items.map((s) => (
                <span class="badge badge-outline font-mono text-xs">{s}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
    <p class="text-xs opacity-60 mt-3">실제 프로젝트에서 사용한 기술만 적었습니다. 사용 맥락은 각 프로젝트 상세에 있습니다.</p>
  </section>

  <!-- Work Experience -->
  <section class="cv-section mb-10">
    <h2 class="cv-h">Work Experience</h2>
    <div class="grid gap-6">
      {
        experience.map((job) => (
          <div class="cv-entry">
            <div class="flex items-baseline justify-between gap-4 flex-wrap">
              <h3 class="text-lg font-bold">
                {job.company} <span class="font-normal opacity-80">· {job.role}</span>
              </h3>
              <span class="font-mono text-sm opacity-60 shrink-0">{job.period}</span>
            </div>
            <p class="text-sm opacity-75 mt-1">{job.summary}</p>
            <ul class="cv-bullets">
              {job.bullets.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="cv-section mb-10">
    <h2 class="cv-h">Featured Projects</h2>
    <div class="grid gap-4">
      {
        featuredProjects.map((p) => (
          <div class="cv-entry">
            <div class="flex items-baseline justify-between gap-4 flex-wrap">
              <h3 class="font-bold">
                <a href={`/projects/${p.slug}/`} class="link link-hover">{p.title}</a>
              </h3>
              <span class="font-mono text-sm opacity-60 shrink-0">{p.period}</span>
            </div>
            <p class="text-sm opacity-75 mt-1 leading-relaxed">{p.summary}</p>
          </div>
        ))
      }
    </div>
    <p class="text-xs opacity-60 mt-3 print:hidden">
      전체 16개 프로젝트의 배경·접근·결과는 <a href="/projects" class="link">Projects</a>에 있습니다.
    </p>
  </section>

  <!-- Education -->
  <section class="cv-section mb-10">
    <h2 class="cv-h">Education</h2>
    <div class="cv-entry">
      <div class="flex items-baseline justify-between gap-4 flex-wrap">
        <h3 class="font-bold">국민대학교 · AI빅데이터융합경영학과 심화전공 · 학사</h3>
        <span class="font-mono text-sm opacity-60 shrink-0">2018.03 – 2024.08</span>
      </div>
      <p class="text-sm opacity-75 mt-1">
        관련 과목: 머신러닝, 딥러닝, 데이터마이닝, 텍스트 데이터 분석, 확률통계, 데이터베이스, 빅데이터 분석
      </p>
    </div>
  </section>

  <!-- Awards -->
  <section class="cv-section mb-10">
    <h2 class="cv-h">Awards</h2>
    <div class="grid gap-4">
      {
        awards.map((a) => (
          <div class="cv-entry">
            <div class="flex items-baseline justify-between gap-4 flex-wrap">
              <h3 class="font-bold">{a.title}</h3>
              <span class="font-mono text-sm opacity-60 shrink-0">{a.date}</span>
            </div>
            <p class="text-sm opacity-75 mt-1">{a.detail}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Competitions -->
  <section class="cv-section mb-10">
    <h2 class="cv-h">Competitions</h2>
    <div class="grid gap-4">
      {
        competitions.map((c) => (
          <div class="cv-entry">
            <div class="flex items-baseline justify-between gap-4 flex-wrap">
              <h3 class="font-bold">{c.title}</h3>
              <span class="font-mono text-sm opacity-60 shrink-0">{c.date}</span>
            </div>
            <p class="text-sm opacity-75 mt-1">
              <span class="font-semibold">{c.result}</span> · {c.detail}
            </p>
          </div>
        ))
      }
    </div>
    <p class="text-xs opacity-60 mt-3">순위는 각 대회의 공개 리더보드 기준입니다.</p>
  </section>

  <!-- Publications -->
  <section class="cv-section mb-10">
    <h2 class="cv-h">Publications</h2>
    <div class="cv-entry">
      <div class="flex items-baseline justify-between gap-4 flex-wrap">
        <h3 class="font-bold">SNP 정보를 활용한 유전체 품종 분류 모델링에 대한 연구</h3>
        <span class="font-mono text-sm opacity-60 shrink-0">2023.02</span>
      </div>
      <p class="text-sm opacity-75 mt-1">
        에이아이프렌즈학회 · 2023년 제2차 실용 인공지능 학술대회 · 연구 논문 제출 및 학술대회 발표
      </p>
    </div>
  </section>

  <!-- Certifications & Languages -->
  <section class="cv-section mb-10">
    <h2 class="cv-h">Certifications &amp; Languages</h2>
    <ul class="cv-bullets">
      <li>제12회 빅데이터분석기사 (필기) · 한국데이터산업진흥원 · 2026.04</li>
      <li>제60회 SQL 개발자 (SQLD) · 한국데이터산업진흥원 · 2026.03</li>
      <li>TOEIC Speaking Test · Intermediate Mid 3 (130점) · 2025.02</li>
    </ul>
  </section>

  <!-- Activities -->
  <section class="cv-section mb-10">
    <h2 class="cv-h">Activities</h2>
    <div class="grid gap-2">
      {
        activities.map((a) => (
          <div class="flex items-baseline justify-between gap-4 flex-wrap">
            <span class="text-sm opacity-85">{a.title}</span>
            <span class="font-mono text-xs opacity-60 shrink-0">{a.date}</span>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
