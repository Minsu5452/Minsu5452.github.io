---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { projects } from "../data/projects";

const tabs = [
  { id: "work", label: "Work" },
  { id: "award", label: "Awards" },
  { id: "comp", label: "Competitions" },
  { id: "academic", label: "Academic" },
] as const;

const grouped = {
  work: projects.filter((p) => p.category === "work"),
  award: projects.filter((p) => p.category === "award"),
  comp: projects.filter((p) => p.category === "comp"),
  academic: projects.filter((p) => p.category === "academic"),
};
---

<BaseLayout
  title="Projects · 강민수"
  description="강민수의 프로젝트 모음 — 업무 프로젝트, 수상 대회, 기타 경진대회, 학부 프로젝트."
  sideBarActiveItemID="projects"
>
  <div>
    <div class="text-3xl w-full font-bold mb-2">Projects</div>
    <p class="text-sm opacity-70 mb-5">카드를 누르면 프로젝트 상세 페이지로 이동합니다.</p>
  </div>

  <div role="tablist" class="tabs tabs-bordered tabs-lg mb-6 text-base md:text-lg font-semibold">
    {
      tabs.map((t, i) => (
        <button
          role="tab"
          class={`tab${i === 0 ? " tab-active" : ""}`}
          data-tab={t.id}
        >
          {t.label}
        </button>
      ))
    }
  </div>

  <div class="tab-stack">
    {
      tabs.map((t, i) => (
        <section data-tab-content={t.id} class={i === 0 ? "active" : ""}>
          <div class="grid gap-4">
            {grouped[t.id as keyof typeof grouped].map((p) => (
              <HorizontalCard
                title={p.title}
                desc={p.summary}
                url={`/projects/${p.slug}/`}
                badge={p.badge}
                hero={p.hero}
                color={p.color}
              />
            ))}
          </div>
        </section>
      ))
    }
  </div>

  <script is:inline>
    document.querySelectorAll('[data-tab]').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const target = btn.dataset.tab;
        document.querySelectorAll('[data-tab]').forEach((b) => {
          b.classList.toggle('tab-active', b === btn);
        });
        document.querySelectorAll('[data-tab-content]').forEach((c) => {
          c.classList.toggle('active', c.dataset.tabContent === target);
        });
      });
    });
  </script>
</BaseLayout>
