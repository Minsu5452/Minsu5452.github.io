---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;

// 성과 칩 스타일: 수상은 강조(솔리드), 나머지는 아웃라인
const resultChipClass = project.category === "award" ? "chip chip-award" : "chip chip-outline";
---

<a
  href={`/projects/${project.slug}/`}
  class="-mx-3 flex items-center gap-5 rounded-lg border-b border-line px-3 py-5 transition-colors last:border-b-0 hover:bg-bg-subtle"
>
  {
    project.hero && (
      <img
        src={project.hero}
        alt=""
        width="88"
        height="55"
        loading="lazy"
        class="thumb-dim h-[55px] w-[88px] flex-none rounded-md border border-line bg-bg-subtle object-cover"
      />
    )
  }
  <div class="min-w-0">
    <div class="text-[17px] font-semibold leading-[1.45] text-ink-strong">{project.title}</div>
    <div class="mt-0.5 truncate text-sm text-ink-muted">{project.summary}</div>
    <div class="mt-2 flex flex-wrap gap-1.5">
      <span class="chip">{project.badge}</span>
      {project.result && <span class={resultChipClass}>{project.result}</span>}
    </div>
  </div>
</a>
