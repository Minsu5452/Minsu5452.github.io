---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { projects } from "../../data/projects";

export async function getStaticPaths() {
  return projects.map((p) => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const accent = project.color ?? "#6366f1";
const categoryLabel: Record<string, string> = {
  work: "Work",
  award: "Awards",
  comp: "Competitions",
  academic: "Academic",
};
---

<BaseLayout
  title={`${project.title} · 강민수`}
  description={project.summary}
  sideBarActiveItemID="projects"
>
  <div class="mb-4">
    <a href="/projects" class="text-sm opacity-70 hover:opacity-100 hover:underline">
      ← Projects
    </a>
  </div>

  <div
    class="relative overflow-hidden rounded-2xl border border-base-300 bg-base-100"
    style={`--accent:${accent};`}
  >
    <span class="absolute inset-x-0 top-0 h-[4px]" style="background:var(--accent);" aria-hidden="true"></span>
    <div class="p-6 md:p-8">
      <div class="text-xs font-mono opacity-70 mb-2 tracking-wide uppercase">
        {categoryLabel[project.category]} · {project.badge}
      </div>
      <h1 class="text-2xl md:text-4xl font-bold leading-tight mb-3">{project.title}</h1>
      <p class="text-base md:text-lg opacity-80">{project.summary}</p>
    </div>
    {
      project.hero && (
        <div class="px-6 pb-6 md:px-8 md:pb-8">
          <img
            src={project.hero}
            alt={project.title}
            width="320"
            height="200"
            loading="eager"
            decoding="async"
            class="w-full max-h-[280px] rounded-xl object-cover"
          />
        </div>
      )
    }
  </div>

  <div class="grid md:grid-cols-3 gap-3 my-6 text-sm">
    <div class="rounded-lg border border-base-300 p-3">
      <div class="opacity-60 text-xs mb-1">기간</div>
      <div class="font-mono">{project.period}</div>
    </div>
    {
      project.role && (
        <div class="rounded-lg border border-base-300 p-3">
          <div class="opacity-60 text-xs mb-1">역할</div>
          <div>{project.role}</div>
        </div>
      )
    }
    <div class="rounded-lg border border-base-300 p-3">
      <div class="opacity-60 text-xs mb-1">소속 / 주최</div>
      <div>{project.org}</div>
    </div>
  </div>

  <div class="prose max-w-none mb-8">
    {
      project.body.map((b) => (
        <div class="mb-5">
          <h2 class="text-xl font-bold mb-2 flex items-center gap-2">
            <span class="inline-block w-1 h-5 rounded" style={`background:${accent};`}></span>
            {b.heading}
          </h2>
          <p class="opacity-85 leading-relaxed">{b.text}</p>
        </div>
      ))
    }
  </div>

  {
    project.architecture && (
      <div class="mb-8">
        <h2 class="text-xl font-bold mb-3 flex items-center gap-2">
          <span class="inline-block w-1 h-5 rounded" style={`background:${accent};`}></span>
          아키텍처
        </h2>
        <img
          src={project.architecture.image}
          alt={project.architecture.alt}
          loading="lazy"
          decoding="async"
          class="w-full rounded-xl border border-base-300"
        />
        {project.architecture.note && (
          <p class="text-sm opacity-70 mt-2">{project.architecture.note}</p>
        )}
      </div>
    )
  }

  {
    project.metrics && project.metrics.length > 0 && (
      <div class="mb-8">
        <h2 class="text-xl font-bold mb-3 flex items-center gap-2">
          <span class="inline-block w-1 h-5 rounded" style={`background:${accent};`}></span>
          핵심 수치
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
          {project.metrics.map((m) => (
            <div class="rounded-lg border border-base-300 p-3">
              <div class="opacity-60 text-xs mb-1">{m.label}</div>
              <div class="font-mono font-semibold">{m.value}</div>
            </div>
          ))}
        </div>
        <p class="text-sm opacity-70 mt-2">저장소 리포트에 저장된 실측값입니다.</p>
      </div>
    )
  }

  {
    project.stack && project.stack.length > 0 && (
      <div class="mb-8">
        <h2 class="text-xl font-bold mb-3 flex items-center gap-2">
          <span class="inline-block w-1 h-5 rounded" style={`background:${accent};`}></span>
          Stack
        </h2>
        <div class="flex flex-wrap gap-2">
          {project.stack.map((s) => (
            <span class="badge badge-outline font-mono text-xs">{s}</span>
          ))}
        </div>
      </div>
    )
  }

  <div class="flex flex-wrap gap-3 mt-8 mb-4">
    {
      project.github && (
        <a
          href={project.github}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-sm md:btn-md"
        >
          GitHub →
        </a>
      )
    }
    {
      project.external?.map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-sm md:btn-md btn-outline"
        >
          {link.label} →
        </a>
      ))
    }
    <a href="/projects" class="btn btn-sm md:btn-md btn-ghost">← All Projects</a>
  </div>
</BaseLayout>
