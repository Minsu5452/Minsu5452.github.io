---
import ThemeToggle from "./ThemeToggle.astro";
import { AUTHOR, AUTHOR_EN, GITHUB_URL } from "../consts";

const pathname = Astro.url.pathname;

const nav = [
  { href: "/", label: "홈" },
  { href: "/projects/", label: "프로젝트" },
  { href: "/articles/", label: "글" },
  { href: "/cv/", label: "CV" },
];

const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<!-- 데스크톱: 좌측 고정 레일 -->
<aside class="site-rail sticky top-0 hidden h-screen w-[220px] flex-none flex-col border-r border-line px-5 py-8 lg:flex">
  <a href="/" class="rounded-md px-2.5 text-[17px] font-bold leading-snug text-ink-strong">
    {AUTHOR}
    <small class="block text-xs font-medium text-ink-muted">{AUTHOR_EN}</small>
  </a>
  <nav class="mt-9 flex flex-col gap-0.5" aria-label="주 메뉴">
    {
      nav.map((item) => (
        <a
          href={item.href}
          aria-current={isActive(item.href) ? "page" : undefined}
          class:list={[
            "rail-link rounded-md px-2.5 py-2 text-[15px] transition-colors hover:bg-bg-subtle hover:text-ink-strong",
            isActive(item.href) ? "font-semibold text-ink-strong" : "font-medium text-ink-muted",
          ]}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
  <div class="mt-auto flex items-center gap-1.5 px-1">
    <a
      href={GITHUB_URL}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="GitHub"
      class="inline-flex h-8 w-8 items-center justify-center rounded-md text-ink-muted transition-colors hover:bg-bg-subtle hover:text-ink-strong"
    >
      <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path
          d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
        ></path>
      </svg>
    </a>
    <ThemeToggle />
  </div>
</aside>

<!-- 모바일: 상단 고정 바 -->
<header class="mobile-bar sticky top-0 z-10 border-b border-line bg-bg lg:hidden">
  <div class="flex h-[52px] items-center gap-5 px-5">
    <a href="/" class="text-base font-bold text-ink-strong">{AUTHOR}</a>
    <nav class="flex gap-4 text-[14px] font-medium" aria-label="주 메뉴">
      {
        nav
          .filter((item) => item.href !== "/")
          .map((item) => (
            <a
              href={item.href}
              aria-current={isActive(item.href) ? "page" : undefined}
              class:list={[
                "transition-colors hover:text-ink-strong",
                isActive(item.href) ? "text-ink-strong" : "text-ink-muted",
              ]}
            >
              {item.label}
            </a>
          ))
      }
    </nav>
    <div class="ml-auto flex items-center">
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  /* 활성 항목: 레일 왼쪽 가장자리에 2px 액센트 바 */
  .rail-link {
    position: relative;
  }
  .rail-link[aria-current="page"]::before {
    content: "";
    position: absolute;
    left: -20px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: var(--accent);
  }
</style>
