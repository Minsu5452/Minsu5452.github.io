---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="flex">
  <div class="education__time">
    <span class="mt-1.5 block h-3 w-3 rounded-full bg-line-strong"></span>
    <span class="education__line block h-full w-[2px] translate-x-[5px] bg-line"></span>
  </div>
  <div class="min-w-0 pb-6 pl-5">
    <h3 class="font-semibold leading-[1.5] text-ink-strong">{title}</h3>
    {subtitle && <span class="text-sm text-ink-muted">{subtitle}</span>}
    {
      Astro.slots.has("default") && (
        <p class="mt-2 text-[15px] leading-relaxed">
          <slot />
        </p>
      )
    }
  </div>
</div>
