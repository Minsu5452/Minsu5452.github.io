    url="https://github.com/Minsu5452/Court_Judgment_Prediction"
    badge="🥈 2등"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="유전체 정보 품종 분류 AI 경진대회 · 1등"
