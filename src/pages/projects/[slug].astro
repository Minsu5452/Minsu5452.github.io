---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleRow from "../../components/ArticleRow.astro";
import CodeCopy from "../../components/CodeCopy.astro";
import TableOfContents from "../../components/TableOfContents.astro";
import { projects } from "../../data/projects";
import { AUTHOR } from "../../consts";

export async function getStaticPaths() {
  const bodies = await getCollection("caseStudies");
  const bodyIds = new Set(bodies.map((b) => b.id));
  const slugs = new Set(projects.map((p) => p.slug));

  // 케이스 스터디 본문과 projects.ts의 1:1 대응을 빌드 타임에 강제한다
  const missing = projects.filter((p) => !bodyIds.has(p.slug)).map((p) => p.slug);
  const orphans = bodies.filter((b) => !slugs.has(b.id)).map((b) => b.id);
  if (missing.length > 0 || orphans.length > 0) {
    throw new Error(
      `케이스 스터디 본문 불일치 — 본문 누락: [${missing.join(", ")}] / projects.ts에 없는 본문 파일: [${orphans.join(", ")}]`,
    );
  }

  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project, body: bodies.find((b) => b.id === project.slug)! },
  }));
}

const { project, body } = Astro.props;
const { Content, headings } = await render(body);

const categoryLabel = {
  work: "실무",
  award: "수상",
  comp: "공모전",
  academic: "학부",
}[project.category];

const resultChipClass = project.category === "award" ? "chip chip-award" : "chip chip-outline";

const relatedArticles = (await getCollection("articles", ({ data }) => !data.draft))
  .filter((article) => article.data.project === project.slug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// 실무 비공개 과제는 레포 링크 대신 사유를 안내한다
const hasRepo = Boolean(project.github);
---

<BaseLayout
  title={`${project.title} · ${AUTHOR}`}
  description={project.summary}
  mainClass="max-w-[760px] xl:max-w-[1040px]"
>
  <div class="xl:grid xl:grid-cols-[minmax(0,1fr)_200px] xl:gap-12">
    <article class="min-w-0 pt-14">
      <a href="/projects/" class="text-[13px] text-ink-muted transition-colors hover:text-accent">
        ← 프로젝트
      </a>

      <header class="mt-6 flex items-start justify-between gap-6">
        <div class="min-w-0">
          <div class="flex flex-wrap gap-1.5">
            <span class="chip">{categoryLabel}</span>
            <span class="chip">{project.badge}</span>
            {project.result && <span class={resultChipClass}>{project.result}</span>}
          </div>
          <h1 class="mt-3 text-2xl font-bold leading-[1.4] text-ink-strong">{project.title}</h1>
          <p class="mt-3 text-[15px] leading-relaxed text-ink-muted">{project.summary}</p>
        </div>
        {
          project.hero && (
            <img
              src={project.hero}
              alt=""
              width="128"
              height="80"
              class="thumb-dim mt-1 hidden h-20 w-32 flex-none rounded-md border border-line bg-bg-subtle object-cover sm:block"
            />
          )
        }
      </header>

      <dl class="mt-8 grid grid-cols-2 gap-4 border-b border-t border-line py-4 text-sm sm:grid-cols-3">
        <div>
          <dt class="text-xs font-medium tracking-[0.04em] text-ink-muted">기간</dt>
          <dd class="mt-1 font-mono text-[13px] text-ink">{project.period}</dd>
        </div>
        <div class="sm:col-span-2">
          <dt class="text-xs font-medium tracking-[0.04em] text-ink-muted">소속 · 주최</dt>
          <dd class="mt-1 text-ink">{project.org}</dd>
        </div>
      </dl>

      <TableOfContents headings={headings} variant="inline" />

      <div class="prose max-w-none pt-4">
        <Content />
      </div>
      <CodeCopy />

      {
        project.stack.length > 0 && (
          <section class="pt-9">
            <h2 class="mb-3 text-[19px] font-bold text-ink-strong">기술 스택</h2>
            <div class="flex flex-wrap gap-1.5">
              {project.stack.map((tech) => (
                <span class="chip chip-outline font-mono text-[12px]">{tech}</span>
              ))}
            </div>
          </section>
        )
      }

      {
        relatedArticles.length > 0 && (
          <section class="pt-9">
            <h2 class="mb-2 text-[19px] font-bold text-ink-strong">이 프로젝트의 글</h2>
            {relatedArticles.map((article) => (
              <ArticleRow article={article} compact />
            ))}
          </section>
        )
      }

      <div class="mt-12 flex flex-wrap items-center gap-3 border-t border-line pt-6">
        {
          hasRepo ? (
            <a
              href={project.github}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-md bg-ink-strong px-4 py-2 text-sm font-medium text-bg transition-opacity hover:opacity-85"
            >
              GitHub →
            </a>
          ) : (
            <span class="text-sm text-ink-muted">실무 과제로 공개 레포가 없습니다.</span>
          )
        }
        {
          project.external?.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-md border border-line-strong px-4 py-2 text-sm font-medium text-ink transition-colors hover:border-accent hover:text-accent"
            >
              {link.label} →
            </a>
          ))
        }
      </div>
    </article>

    <aside class="hidden pt-14 xl:block">
      <div class="sticky top-10">
        <TableOfContents headings={headings} variant="rail" />
      </div>
    </aside>
  </div>
</BaseLayout>
