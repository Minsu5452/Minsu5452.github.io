---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { featuredProjects, projects } from "../data/projects";
import { getCollection } from "astro:content";

const latestNotes = (await getCollection("notes"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
const accentOf = (slug?: string) =>
  projects.find((p) => p.slug === slug)?.color ?? "#6366f1";
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-5xl font-bold">강민수 · Minsu Kang</div>
    <div class="text-3xl py-3 font-bold break-keep">LLM 에이전트와 ML 시스템을 만들고, 실제로 돌아가는 서비스로 배포합니다.</div>
    <div class="py-2">
      <p class="text-lg">
        데이콘 Data Science팀 매니저로 <b>공공 데이터 분석 과제 2건을 PL</b>로 맡고 있습니다.<br />
        법령 RAG 에이전트부터 사고 위험 통계 검증, <b>망분리 환경 오프라인 배포</b>까지<br />
        모델이 실제 서비스로 이어지는 구간을 만들어 왔습니다.
      </p>
    </div>
    <div class="mt-8 flex flex-wrap gap-3">
      <a class="btn btn-outline" href="/projects">Projects</a>
      <a class="btn btn-outline" href="/cv">CV</a>
      <a
        class="btn btn-outline gap-1"
        href="https://github.com/Minsu5452"
        target="_blank"
        rel="noopener noreferrer"
      >
        GitHub
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M7 17L17 7"/><path d="M7 7h10v10"/>
        </svg>
      </a>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-2">대표 프로젝트</div>
    <p class="text-sm opacity-70 mb-5">카드를 누르면 프로젝트 상세 페이지로 이동합니다.</p>
  </div>

  <div class="grid gap-4">
    {
      featuredProjects.map((p) => (
        <HorizontalCard
          title={p.title}
          desc={p.summary}
          url={`/projects/${p.slug}/`}
          badge={p.badge}
          hero={p.hero}
          color={p.color}
        />
      ))
    }
  </div>

  <div class="mt-10 text-center">
    <a class="btn btn-outline" href="/projects">전체 프로젝트 보기 →</a>
  </div>

  <div class="mt-14">
    <div class="text-3xl w-full font-bold mb-2">기술 노트</div>
    <p class="text-sm opacity-70 mb-5">
      프로젝트에서 나온 설계 판단의 이유와 실측, 현장에서 배운 점을 기록합니다.
    </p>
    <div class="grid gap-3">
      {
        latestNotes.map((note) => (
          <a
            href={`/notes/${note.slug}/`}
            class="group relative block overflow-hidden rounded-lg border border-base-300 bg-base-100 p-4 transition-all duration-200 hover:-translate-y-0.5 hover:border-primary/40 hover:shadow-[0_10px_28px_-14px_rgba(0,0,0,0.2)]"
            style={`--accent:${accentOf(note.data.project)};`}
          >
            <span
              class="pointer-events-none absolute inset-y-0 left-0 w-[3px] opacity-70"
              style="background:var(--accent);"
              aria-hidden="true"
            />
            <div class="text-xs font-mono opacity-60 mb-1 uppercase tracking-wide">{note.data.topic}</div>
            <div class="font-semibold leading-snug">{note.data.title}</div>
            <span
              class="pointer-events-none absolute right-4 top-4 text-base-content/40 opacity-0 transition-all duration-200 group-hover:translate-x-0.5 group-hover:opacity-100"
              aria-hidden="true"
            >
              →
            </span>
          </a>
        ))
      }
    </div>
    <div class="mt-6 text-center">
      <a class="btn btn-outline" href="/notes">전체 노트 보기 →</a>
    </div>
  </div>
</BaseLayout>
