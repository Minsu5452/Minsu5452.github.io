---
import BaseLayout from "../layouts/BaseLayout.astro";
import { AUTHOR } from "../consts";
---

<BaseLayout title={`404 · ${AUTHOR}`} description="찾으시는 페이지가 없습니다.">
  <div class="flex flex-col items-start py-28">
    <p class="font-mono text-sm text-ink-muted">404</p>
    <h1 class="mt-2 text-2xl font-bold text-ink-strong">찾으시는 페이지가 없습니다.</h1>
    <p class="mt-3 text-[15px] text-ink-muted">주소가 바뀌었거나 삭제된 페이지일 수 있습니다.</p>
    <a
      href="/"
      class="mt-8 rounded-md bg-ink-strong px-4 py-2 text-sm font-medium text-bg transition-opacity hover:opacity-85"
    >
      홈으로 →
    </a>
  </div>
</BaseLayout>
