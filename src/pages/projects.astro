---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Projects · 강민수" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-2">Projects</div>
    <p class="text-sm opacity-70 mb-5">카드를 누르면 GitHub 저장소로 이동합니다.</p>
  </div>

  <div class="text-2xl w-full font-bold mb-3 mt-6">💼 Work Projects</div>

  <HorizontalCard
    title="LLM 평가 시스템 (Council 2단계 채점)"
    desc="여러 LLM 응답을 Council 방식으로 2단계 채점. FastAPI + Redis Queue + asyncio. 데이콘 평가 인프라."
    url="https://github.com/Minsu5452/LLM_Evaluation_System"
    badge="2026 · 데이콘"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="운수종사자 교통사고 위험 예측 모델·관리 웹"
    desc="행안부·NIA·한국교통안전공단 위탁사업. 2025년 경진대회 솔루션(34등/437팀)을 모델 기반으로 삼아 ML 모델 + 관리자 웹 (React/Vite/Mantine) + AI 엔진 (FastAPI) + 배포 (Spring Boot/eGovFrame, Nginx, Docker)까지 단독 개발."
    url="https://github.com/Minsu5452/Driver_Risk_Web_Platform"
    badge="2026 · 데이콘"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="해양사고 위험 예측 시스템"
    desc="LightGBM 5-fold CV (OOF AUC=0.946) + SHAP + FastAPI + Streamlit pydeck 격자 대시보드 + Docker. 슈어소프트테크 AI융복합 프로젝트 재현."
    url="https://github.com/Minsu5452/Marine_Accident_Risk_Prediction"
    badge="2025 · 슈어소프트테크"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="해양 법령 도메인 RAG (CDX)"
    desc="국가법령정보 OPEN API → 12개 해양 법령·394 조문. KR-SBERT + FAISS + BM25 hybrid + GraphRAG (1.2K nodes / 91K edges) + LangGraph 6-node workflow + EXAONE-3.5-2.4B GGUF (CPU)."
    url="https://github.com/Minsu5452/Marine_Domain_RAG"
    badge="2025 · 슈어소프트테크"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="KT 에이전트 검증 데이터셋 구축"
    desc="KT 에이전트 시스템 검증용 데이터셋 큐레이션. 슈어소프트테크 인턴 시 참여. (회사 자산이라 별도 공개 레포 없음)"
    url="https://github.com/Minsu5452"
    badge="2025 · 슈어소프트테크"
  />

