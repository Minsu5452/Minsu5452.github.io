---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CodeCopy from "../../components/CodeCopy.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import TableOfContents from "../../components/TableOfContents.astro";
import { projects } from "../../data/projects";
import { AUTHOR } from "../../consts";

export async function getStaticPaths() {
  const articles = (await getCollection("articles", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );
  return articles.map((article, i) => ({
    params: { slug: article.id },
    // 최신순 정렬 기준: 앞이 다음(새) 글, 뒤가 이전(옛) 글
    props: { article, newer: articles[i - 1] ?? null, older: articles[i + 1] ?? null },
  }));
}

const { article, newer, older } = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await render(article);
const readingMinutes: number = remarkPluginFrontmatter.readingMinutes;

const relatedProject = projects.find((p) => p.slug === article.data.project);
---

<BaseLayout
  title={`${article.data.title} · ${AUTHOR}`}
  description={article.data.description}
  ogType="article"
  pubDate={article.data.pubDate}
  updatedDate={article.data.updatedDate}
  mainClass="max-w-[760px] xl:max-w-[1040px]"
>
  <div class="xl:grid xl:grid-cols-[minmax(0,1fr)_200px] xl:gap-12">
    <article class="min-w-0 pt-14">
      <a href="/articles/" class="text-[13px] text-ink-muted transition-colors hover:text-accent">
        ← 글
      </a>

      <header class="mt-6 border-b border-line pb-7">
        <div class="flex flex-wrap items-center gap-2 text-[13px] text-ink-muted">
          <span class="chip">{article.data.topic}</span>
          <FormattedDate date={article.data.pubDate} />
          {
            article.data.updatedDate && (
              <span>
                (수정 <FormattedDate date={article.data.updatedDate} />)
              </span>
            )
          }
          <span aria-hidden="true">·</span>
          <span>{readingMinutes}분 분량</span>
        </div>
        <h1 class="mt-2.5 text-2xl font-bold leading-[1.4] text-ink-strong">
          {article.data.title}
        </h1>
        <p class="mt-3 text-[15px] leading-relaxed text-ink-muted">{article.data.description}</p>
        {
          article.data.tags.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-1.5">
              {article.data.tags.map((tag) => (
                <span class="chip">{tag}</span>
              ))}
            </div>
          )
        }
      </header>

      <TableOfContents headings={headings} variant="inline" />

      <div class="prose max-w-none pt-8">
        <Content />
      </div>
      <CodeCopy />

      {
        relatedProject && (
          <aside class="mt-12 border-t border-line pt-6">
            <h2 class="text-sm font-medium text-ink-muted">관련 프로젝트</h2>
            <a
              href={`/projects/${relatedProject.slug}/`}
              class="group mt-3 flex items-center gap-4 rounded-lg border border-line p-4 transition-colors hover:border-line-strong hover:bg-bg-subtle"
            >
              {relatedProject.hero && (
                <img
                  src={relatedProject.hero}
                  alt=""
                  width="72"
                  height="45"
                  loading="lazy"
                  class="thumb-dim h-[45px] w-[72px] flex-none rounded border border-line object-cover"
                />
              )}
              <div class="min-w-0">
                <div class="font-semibold text-ink-strong transition-colors group-hover:text-accent">
                  {relatedProject.title}
                </div>
                <div class="mt-0.5 truncate text-sm text-ink-muted">{relatedProject.summary}</div>
              </div>
            </a>
          </aside>
        )
      }

      {
        (older || newer) && (
          <nav class="mt-12 grid gap-3 border-t border-line pt-6 sm:grid-cols-2" aria-label="이전·다음 글">
            {older && (
              <a
                href={`/articles/${older.id}/`}
                class="group rounded-lg border border-line p-4 transition-colors hover:border-line-strong hover:bg-bg-subtle"
              >
                <span class="text-xs text-ink-muted">← 이전 글</span>
                <span class="mt-1 block text-sm font-medium leading-snug text-ink-strong transition-colors group-hover:text-accent">
                  {older.data.title}
                </span>
              </a>
            )}
            {newer && (
              <a
                href={`/articles/${newer.id}/`}
                class="group rounded-lg border border-line p-4 text-right transition-colors hover:border-line-strong hover:bg-bg-subtle sm:col-start-2"
              >
                <span class="text-xs text-ink-muted">다음 글 →</span>
                <span class="mt-1 block text-sm font-medium leading-snug text-ink-strong transition-colors group-hover:text-accent">
                  {newer.data.title}
                </span>
              </a>
            )}
          </nav>
        )
      }
    </article>

    <aside class="hidden pt-14 xl:block">
      <div class="sticky top-10">
        <TableOfContents headings={headings} variant="rail" />
      </div>
    </aside>
  </div>
</BaseLayout>
