---
import type { CollectionEntry } from "astro:content";
import FormattedDate from "./FormattedDate.astro";

interface Props {
  article: CollectionEntry<"articles">;
  /** 홈·관련 글 목록용 한 줄 표시 */
  compact?: boolean;
}

const { article, compact = false } = Astro.props;
---

{
  compact ? (
    <a
      href={`/articles/${article.id}/`}
      class="group -mx-3 flex items-baseline gap-4 rounded-lg border-b border-line px-3 py-3.5 transition-colors last:border-b-0 hover:bg-bg-subtle"
    >
      <span class="flex-none text-[13px] text-ink-muted">
        <FormattedDate date={article.data.pubDate} />
      </span>
      <span class="min-w-0 truncate font-medium text-ink-strong transition-colors group-hover:text-accent">
        {article.data.title}
      </span>
    </a>
  ) : (
    <a
      href={`/articles/${article.id}/`}
      class="group -mx-3 block rounded-lg border-b border-line px-3 py-5 transition-colors last:border-b-0 hover:bg-bg-subtle"
    >
      <div class="flex flex-wrap items-center gap-2 text-[13px] text-ink-muted">
        <span class="chip">{article.data.topic}</span>
        <FormattedDate date={article.data.pubDate} />
      </div>
      <div class="mt-2 text-[17px] font-semibold leading-[1.45] text-ink-strong transition-colors group-hover:text-accent">
        {article.data.title}
      </div>
      <p class="mt-1 text-sm leading-relaxed text-ink-muted">{article.data.description}</p>
    </a>
  )
}
