---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { projects } from "../../data/projects";

const notes = (await getCollection("notes")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const projectOf = (slug?: string) => projects.find((p) => p.slug === slug);
const fmt = (d: Date) =>
  `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, "0")}.${String(d.getDate()).padStart(2, "0")}`;
---

<BaseLayout
  title="Notes · 강민수"
  description="프로젝트에서 나온 기술 정리와 회고 — 설계 판단의 이유, 실측이 가설을 뒤집은 기록, 저장소 README에 다 담기 어려운 현장의 맥락."
  sideBarActiveItemID="notes"
>
  <div>
    <div class="text-3xl w-full font-bold mb-2">Notes</div>
    <p class="text-sm opacity-70 mb-6 leading-relaxed">
      프로젝트에서 나온 기술 정리와 회고입니다. 어떤 기술을 왜 골랐고 무엇을 실측으로 확인했는지,
      그리고 저장소 README에 다 담기 어려운 현장의 맥락과 배운 점을 기록합니다.
    </p>
  </div>

  <div class="grid gap-4">
    {
      notes.map((note) => {
        const related = projectOf(note.data.project);
        const accent = related?.color ?? "#6366f1";
        return (
          <a
            href={`/notes/${note.slug}/`}
            class="group relative block overflow-hidden rounded-xl border border-base-300 bg-base-100 p-5 md:p-6 transition-all duration-200 hover:-translate-y-0.5 hover:border-primary/40 hover:shadow-[0_10px_28px_-14px_rgba(0,0,0,0.2)] active:translate-y-0"
            style={`--accent:${accent};`}
          >
            <span
              class="pointer-events-none absolute inset-y-0 left-0 w-[3px] opacity-70 transition-opacity duration-200 group-hover:opacity-100"
              style="background:var(--accent);"
              aria-hidden="true"
            />
            <div class="flex items-center gap-2 text-xs font-mono opacity-70 mb-2 tracking-wide">
              <span class="uppercase">{note.data.topic}</span>
              <span aria-hidden="true">·</span>
              <time datetime={note.data.pubDate.toISOString()}>{fmt(note.data.pubDate)}</time>
            </div>
            <h2 class="text-lg md:text-xl font-bold leading-snug">{note.data.title}</h2>
            <p class="mt-2 text-sm md:text-base opacity-75 leading-relaxed">{note.data.description}</p>
            <div class="mt-3 flex flex-wrap items-center gap-2">
              {note.data.tags.map((tag) => (
                <span class="badge badge-outline font-mono text-xs">{tag}</span>
              ))}
              {related && (
                <span class="text-xs opacity-60 ml-auto">프로젝트 · {related.title}</span>
              )}
            </div>
            <span
              class="pointer-events-none absolute right-4 top-4 text-base-content/40 opacity-0 transition-all duration-200 group-hover:translate-x-0.5 group-hover:opacity-100"
              aria-hidden="true"
            >
              →
            </span>
          </a>
        );
      })
    }
  </div>
</BaseLayout>
