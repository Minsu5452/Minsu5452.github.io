---
import type { MarkdownHeading } from "astro";

interface Props {
  headings: MarkdownHeading[];
  variant?: "rail" | "inline";
}

const { headings, variant = "rail" } = Astro.props;

// h2·h3만 목차로 노출하고, 항목이 적으면 목차 자체를 생략한다.
const items = headings.filter((h) => h.depth === 2 || h.depth === 3);
const show = items.length >= 4;
---

{
  show && variant === "rail" && (
    <nav class="toc" aria-label="목차">
      <p class="mb-2 text-xs font-semibold tracking-[0.04em] text-ink-strong">목차</p>
      {items.map((h) => (
        <a href={`#${h.slug}`} data-depth={h.depth}>
          {h.text}
        </a>
      ))}
    </nav>
  )
}

{
  show && variant === "inline" && (
    <details class="mt-8 rounded-lg border border-line px-4 py-3 xl:hidden">
      <summary class="cursor-pointer text-sm font-semibold text-ink-strong">목차</summary>
      <nav class="toc mt-2" aria-label="목차">
        {items.map((h) => (
          <a href={`#${h.slug}`} data-depth={h.depth}>
            {h.text}
          </a>
        ))}
      </nav>
    </details>
  )
}
