---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import { projects } from "../../data/projects";
import { AUTHOR } from "../../consts";

export async function getStaticPaths() {
  const notes = await getCollection("notes", ({ data }) => !data.draft);
  return notes.map((note) => ({ params: { slug: note.id }, props: { note } }));
}

const { note } = Astro.props;
const { Content } = await render(note);

const relatedProject = projects.find((p) => p.slug === note.data.project);
---

<BaseLayout
  title={`${note.data.title} · ${AUTHOR}`}
  description={note.data.description}
  ogType="article"
  pubDate={note.data.pubDate}
  updatedDate={note.data.updatedDate}
>
  <article class="pt-14">
    <a href="/notes/" class="text-[13px] text-ink-muted transition-colors hover:text-accent">
      ← 노트
    </a>

    <header class="mt-6 border-b border-line pb-7">
      <div class="flex flex-wrap items-center gap-2 text-[13px] text-ink-muted">
        <FormattedDate date={note.data.pubDate} />
        {
          note.data.updatedDate && (
            <span>
              (수정 <FormattedDate date={note.data.updatedDate} />)
            </span>
          )
        }
      </div>
      <h1 class="mt-2.5 text-2xl font-bold leading-[1.4] text-ink-strong">{note.data.title}</h1>
      <p class="mt-3 text-[15px] leading-relaxed text-ink-muted">{note.data.description}</p>
      {
        note.data.tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-1.5">
            {note.data.tags.map((tag) => (
              <span class="chip">{tag}</span>
            ))}
          </div>
        )
      }
    </header>

    <div class="prose max-w-none pt-8">
      <Content />
    </div>

    {
      relatedProject && (
        <aside class="mt-12 border-t border-line pt-6">
          <h2 class="text-sm font-medium text-ink-muted">관련 프로젝트</h2>
          <a
            href={`/projects/${relatedProject.slug}/`}
            class="group mt-3 flex items-center gap-4 rounded-lg border border-line p-4 transition-colors hover:border-line-strong hover:bg-bg-subtle"
          >
            {relatedProject.hero && (
              <img
                src={relatedProject.hero}
                alt=""
                width="72"
                height="45"
                loading="lazy"
                class="thumb-dim h-[45px] w-[72px] flex-none rounded border border-line object-cover"
              />
            )}
            <div class="min-w-0">
              <div class="font-semibold text-ink-strong transition-colors group-hover:text-accent">
                {relatedProject.title}
              </div>
              <div class="mt-0.5 truncate text-sm text-ink-muted">{relatedProject.summary}</div>
            </div>
          </a>
        </aside>
      )
    }
  </article>
</BaseLayout>
