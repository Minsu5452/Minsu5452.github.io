---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
import { AUTHOR, AUTHOR_EN, EMAIL, GITHUB_URL, DACON_URL } from "../consts";

const skills = [
  { group: "LLM · Agent", items: ["LangGraph", "LangChain", "OpenAI API", "Hugging Face", "Qdrant", "Neo4j"] },
  { group: "ML · 데이터", items: ["PyTorch", "scikit-learn", "LightGBM", "XGBoost", "CatBoost", "pandas"] },
  { group: "서빙 · 인프라", items: ["FastAPI", "Redis", "PostgreSQL", "Docker", "Nginx", "GitHub Actions"] },
  { group: "웹", items: ["React", "Next.js", "TypeScript"] },
];
---

<BaseLayout
  title={`CV · ${AUTHOR}`}
  description={`${AUTHOR} | ${AUTHOR_EN}의 이력 — Work Experience, Skills, Awards, Competitions, Publications, Education, Certifications, Activities, Languages.`}
>
  <header class="cv-header pt-14">
    <p class="mb-2 font-mono text-xs uppercase tracking-widest text-ink-muted">Curriculum Vitae</p>
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div class="grow">
        <h1 class="text-3xl font-bold leading-tight tracking-tight text-ink-strong sm:text-4xl">
          {AUTHOR}
        </h1>
        <p class="mt-1 text-lg text-ink-muted">{AUTHOR_EN}</p>
        <p class="mt-4 font-semibold text-ink-strong">
          LLM 에이전트와 ML 시스템을 만들고, 실제로 돌아가는 서비스로 배포합니다.
        </p>
      </div>
      <button
        type="button"
        class="print-hidden rounded-md border border-line-strong px-3.5 py-1.5 text-sm font-medium text-ink transition-colors hover:border-accent hover:text-accent"
        onclick="window.print()"
        aria-label="이력서 인쇄"
      >
        Print
      </button>
    </div>

    <dl
      id="contact"
      class="cv-meta mt-6 grid grid-cols-1 gap-x-6 gap-y-2 border-b border-t border-line py-4 text-sm md:grid-cols-3"
    >
      <div class="flex gap-2">
        <dt class="w-16 shrink-0 font-mono uppercase tracking-wide text-ink-muted">Email</dt>
        <dd><a href={`mailto:${EMAIL}`} class="hover:text-accent">{EMAIL}</a></dd>
      </div>
      <div class="flex gap-2">
        <dt class="w-16 shrink-0 font-mono uppercase tracking-wide text-ink-muted">GitHub</dt>
        <dd>
          <a href={GITHUB_URL} target="_blank" rel="noopener" class="hover:text-accent">Minsu5452</a>
        </dd>
      </div>
      <div class="flex gap-2">
        <dt class="w-16 shrink-0 font-mono uppercase tracking-wide text-ink-muted">DACON</dt>
        <dd>
          <a href={DACON_URL} target="_blank" rel="noopener" class="hover:text-accent">View profile</a>
        </dd>
      </div>
      <div class="flex gap-2">
        <dt class="w-16 shrink-0 font-mono uppercase tracking-wide text-ink-muted">Based</dt>
        <dd>Seoul, South Korea</dd>
      </div>
      <div class="flex gap-2">
        <dt class="w-16 shrink-0 font-mono uppercase tracking-wide text-ink-muted">Now</dt>
        <dd>데이콘 · Data Science팀 매니저</dd>
      </div>
      <div class="flex gap-2">
        <dt class="w-16 shrink-0 font-mono uppercase tracking-wide text-ink-muted">Edu</dt>
        <dd>국민대 · AI빅데이터융합경영학과</dd>
      </div>
    </dl>
  </header>

  <!-- Profile -->
  <section class="cv-section pt-10">
    <h2 class="cv-h">Profile</h2>
    <p class="leading-relaxed">
      교통·해양·법률 등 여러 도메인에서 ML 모델·LLM/RAG 시스템·웹 서비스를 설계·개발한 경험이
      있습니다. 현재 데이콘에서 공공 데이터 분석 과제 PL과 대회 기획·운영, AI 시스템 개발을 함께
      다루고 있습니다. 검색 전략과 모델 성능은 골드셋과 통계 검정으로 직접 평가해 근거와 함께
      공개합니다.
    </p>
  </section>

  <!-- Work Experience -->
  <section class="cv-section pt-10">
    <h2 class="cv-h">Work Experience</h2>
    <div class="time-line-container">
      <TimeLineElement title="데이콘 · Data Science팀 매니저" subtitle="2025.12.29 – 현재">
        공공 데이터 분석 과제 2건을 PL로 수행. 행안부·NIA·한국교통안전공단 위탁 운수종사자 교통사고
        위험 예측 모델·관리 웹 개발, 조달청 수요기관 자체입찰 모니터링 모델 개발(진행 중). LLM 평가
        시스템 개발 (Council 채점, FastAPI/Redis/asyncio)과 대회 기획·운영.
      </TimeLineElement>
      <TimeLineElement
        title="슈어소프트테크 · AX응용기술팀 AI 개발자 (인턴)"
        subtitle="2025.06.02 – 2025.11.30"
      >
        해양수산부 AI융복합 과제로 해양사고 위험 예측 시스템 개발(격자×시간 단위 데이터 설계 ·
        위험 예측 모델 · SHAP). 해양경찰청 CDX 과제로 해양 법령 도메인 RAG DB 구축(GraphRAG ·
        LangGraph 기반 검색·답변 흐름 구성에 참여). KT 자율 에이전트 검증 데이터셋 큐레이션.
      </TimeLineElement>
    </div>
  </section>

  <!-- Skills -->
  <section class="cv-section pt-4">
    <h2 class="cv-h">Skills</h2>
    <dl class="grid gap-3">
      {
        skills.map((row) => (
          <div class="flex flex-col gap-1.5 sm:flex-row sm:items-baseline">
            <dt class="w-32 shrink-0 text-sm font-medium text-ink-muted">{row.group}</dt>
            <dd class="flex flex-wrap gap-1.5">
              {row.items.map((item) => (
                <span class="chip chip-outline">{item}</span>
              ))}
            </dd>
          </div>
        ))
      }
    </dl>
  </section>

  <!-- Awards -->
  <section class="cv-section pt-10">
    <h2 class="cv-h">Awards</h2>
    <div class="time-line-container">
      <TimeLineElement
        title="법원 판결 예측 AI 경진대회 · 2등"
        subtitle="2023.07.26 · 데이콘 주최/주관"
      />
      <TimeLineElement
        title="유전체 정보 품종 분류 AI 경진대회 · 1등"
        subtitle="2023.02.14 · 충남대학교 바이오AI융합연구센터 주최 · 데이콘 주관"
      />
    </div>
  </section>

  <!-- Competitions -->
  <section class="cv-section pt-4">
    <h2 class="cv-h">Competitions</h2>
    <div class="time-line-container">
      <TimeLineElement
        title="제3회 국민대학교 AI빅데이터 분석 경진대회 · 상위 5.2% (50등/960팀)"
        subtitle="2025.11.10 – 2025.11.28"
      />
      <TimeLineElement
        title="운수종사자 인지적 특성 데이터 활용 교통사고 위험 예측 AI 경진대회 · 상위 7.8% (34등/437팀)"
        subtitle="2025.10.13 – 2025.11.14 · 행정안전부·NIA 주최 · 한국교통안전공단 주관"
      />
      <TimeLineElement
        title="HD현대 AI Challenge · 예선 2등 / 본선 6등"
        subtitle="2023.09.25 – 2023.10.30 · HD한국조선해양 AI Center 주최 · 데이콘 주관"
      />
      <TimeLineElement
        title="2023 전력사용량 예측 AI 경진대회 · 상위 8.7% (107등/1,233팀)"
        subtitle="2023.07.17 – 2023.08.28 · 한국에너지공단 주최 · 데이콘 주관"
      />
      <TimeLineElement
        title="온라인 채널 제품 판매량 예측 AI 온라인 해커톤 · 예선 12등 / 본선 24등"
        subtitle="2023.08.01 – 2023.08.28 · LG AI Research 주최 · 데이콘 주관 · LG Aimers 연계"
      />
      <TimeLineElement
        title="감귤 착과량 예측 AI 경진대회 · 상위 6.6% (17등/257팀)"
        subtitle="2022.12.12 – 2022.12.14 · 제주테크노파크 주최 · 데이콘 주관"
      />
    </div>
  </section>

  <!-- Publications -->
  <section class="cv-section pt-4">
    <h2 class="cv-h">Publications</h2>
    <div class="time-line-container">
      <TimeLineElement
        title="SNP 정보를 활용한 유전체 품종 분류 모델링에 대한 연구"
        subtitle="2023.02.09 – 2023.02.10 · 에이아이프렌즈학회 · 2023년 제2차 실용 인공지능 학술대회"
      >
        연구 논문 제출 및 학술대회 발표.
      </TimeLineElement>
    </div>
  </section>

  <!-- Education -->
  <section class="cv-section pt-4">
    <h2 class="cv-h">Education</h2>
    <div class="time-line-container">
      <TimeLineElement
        title="국민대학교 · AI빅데이터융합경영학과 심화전공 · 학사"
        subtitle="2018.03 – 2024.08 졸업 · 관련 과목: 머신러닝, 딥러닝, 텍스트 데이터 분석"
      />
    </div>
  </section>

  <!-- Certifications -->
  <section class="cv-section pt-4">
    <h2 class="cv-h">Certifications</h2>
    <ul class="mx-5 grid list-disc gap-2 text-[15px]">
      <li>제12회 빅데이터분석기사 (필기) · 한국데이터산업진흥원 · 2026.04.24</li>
      <li>제60회 SQL 개발자 (SQLD) · 한국데이터산업진흥원 · 2026.03.27</li>
    </ul>
  </section>

  <!-- Activities -->
  <section class="cv-section pt-10">
    <h2 class="cv-h">Activities</h2>
    <div class="time-line-container">
      <TimeLineElement
        title="국민대학교 경영대학 · 연결고리 14기 멘티"
        subtitle="2023.10.06 – 2023.11.23 · 현업 동문 선배 진로 멘토링 프로그램"
      />
      <TimeLineElement
        title="BDA (현 BDAI, 대학생 연합 빅데이터 학회) · 7기 데이터 분석 고급반 수료"
        subtitle="2023.09.01 – 2024.03.31"
      />
      <TimeLineElement
        title="LG AI Research · LG Aimers 3기 교육생"
        subtitle="2023.07.01 – 2023.09.27 · LG 청년 AI 인재 양성 프로그램"
      />
      <TimeLineElement title="D&A (국민대학교 빅데이터 분석 학회) · 딥러닝 세션" subtitle="2023.03.01 – 2023.12.31" />
      <TimeLineElement title="D&A · 머신러닝 세션" subtitle="2022.03.01 – 2022.12.31" />
      <TimeLineElement title="D&A · Python 기초 스터디" subtitle="2021.12.01 – 2022.01.31" />
    </div>
  </section>

  <!-- Languages -->
  <section class="cv-section pt-4 pb-6">
    <h2 class="cv-h">Languages</h2>
    <ul class="mx-5 grid list-disc gap-2 text-[15px]">
      <li>TOEIC Speaking Test · Intermediate Mid 3 (130점) · 2025.02.22</li>
    </ul>
  </section>
</BaseLayout>
