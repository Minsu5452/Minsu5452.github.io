---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import { projects } from "../../data/projects";
import { AUTHOR } from "../../consts";

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

const categoryLabel = {
  work: "실무",
  award: "수상",
  comp: "공모전",
  academic: "학부",
}[project.category];

const resultChipClass = project.category === "award" ? "chip chip-award" : "chip chip-outline";

const relatedNotes = (await getCollection("notes", ({ data }) => !data.draft))
  .filter((note) => note.data.project === project.slug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// 실무 비공개 과제는 레포 링크 대신 사유를 안내한다
const hasRepo = Boolean(project.github);
---

<BaseLayout title={`${project.title} · ${AUTHOR}`} description={project.summary}>
  <article class="pt-14">
    <a href="/projects/" class="text-[13px] text-ink-muted transition-colors hover:text-accent">
      ← 프로젝트
    </a>

    <header class="mt-6 flex items-start justify-between gap-6">
      <div class="min-w-0">
        <div class="flex flex-wrap gap-1.5">
          <span class="chip">{categoryLabel}</span>
          <span class="chip">{project.badge}</span>
          {project.result && <span class={resultChipClass}>{project.result}</span>}
        </div>
        <h1 class="mt-3 text-2xl font-bold leading-[1.4] text-ink-strong">{project.title}</h1>
        <p class="mt-3 text-[15px] leading-relaxed text-ink-muted">{project.summary}</p>
      </div>
      {
        project.hero && (
          <img
            src={project.hero}
            alt=""
            width="128"
            height="80"
            class="thumb-dim mt-1 hidden h-20 w-32 flex-none rounded-md border border-line bg-bg-subtle object-cover sm:block"
          />
        )
      }
    </header>

    <dl class="mt-8 grid grid-cols-2 gap-4 border-b border-t border-line py-4 text-sm sm:grid-cols-3">
      <div>
        <dt class="text-xs font-medium tracking-[0.04em] text-ink-muted">기간</dt>
        <dd class="mt-1 font-mono text-[13px] text-ink">{project.period}</dd>
      </div>
      <div class="sm:col-span-2">
        <dt class="text-xs font-medium tracking-[0.04em] text-ink-muted">소속 · 주최</dt>
        <dd class="mt-1 text-ink">{project.org}</dd>
      </div>
    </dl>

    {
      project.body.map((section) => (
        <section class="pt-9">
          <h2 class="mb-2.5 text-[19px] font-bold text-ink-strong">{section.heading}</h2>
          <p class="leading-relaxed">{section.text}</p>
        </section>
      ))
    }

    {
      project.stack.length > 0 && (
        <section class="pt-9">
          <h2 class="mb-3 text-[19px] font-bold text-ink-strong">기술 스택</h2>
          <div class="flex flex-wrap gap-1.5">
            {project.stack.map((tech) => (
              <span class="chip chip-outline font-mono text-[12px]">{tech}</span>
            ))}
          </div>
        </section>
      )
    }

    {
      relatedNotes.length > 0 && (
        <section class="pt-9">
          <h2 class="mb-2 text-[19px] font-bold text-ink-strong">관련 노트</h2>
          {relatedNotes.map((note) => (
            <a
              href={`/notes/${note.id}/`}
              class="group -mx-3 flex items-baseline gap-4 rounded-lg border-b border-line px-3 py-3.5 transition-colors last:border-b-0 hover:bg-bg-subtle"
            >
              <span class="flex-none text-[13px] text-ink-muted">
                <FormattedDate date={note.data.pubDate} />
              </span>
              <span class="font-medium text-ink-strong transition-colors group-hover:text-accent">
                {note.data.title}
              </span>
            </a>
          ))}
        </section>
      )
    }

    <div class="mt-12 flex flex-wrap items-center gap-3 border-t border-line pt-6">
      {
        hasRepo ? (
          <a
            href={project.github}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-md bg-ink-strong px-4 py-2 text-sm font-medium text-bg transition-opacity hover:opacity-85"
          >
            GitHub →
          </a>
        ) : (
          <span class="text-sm text-ink-muted">실무 과제로 공개 레포가 없습니다.</span>
        )
      }
      {
        project.external?.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-md border border-line-strong px-4 py-2 text-sm font-medium text-ink transition-colors hover:border-accent hover:text-accent"
          >
            {link.label} →
          </a>
        ))
      }
    </div>
  </article>
</BaseLayout>
