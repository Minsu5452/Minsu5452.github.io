---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleRow from "../../components/ArticleRow.astro";
import { AUTHOR } from "../../consts";

const articles = (await getCollection("articles", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout
  title={`글 · ${AUTHOR}`}
  description="프로젝트에서 쓴 기술을 정리합니다. 개념과 설계 판단, 실무 적용에서 배운 것까지."
>
  <header class="pb-2 pt-14">
    <h1 class="text-2xl font-bold text-ink-strong">글</h1>
    <p class="mt-2 text-[15px] text-ink-muted">
      프로젝트에서 쓴 기술을 정리합니다. 개념과 설계 판단, 실무 적용에서 배운 것까지.
    </p>
  </header>

  <div class="pt-6">
    {articles.map((article) => <ArticleRow article={article} />)}
  </div>
</BaseLayout>
